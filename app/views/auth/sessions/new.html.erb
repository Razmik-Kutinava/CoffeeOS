<div class="w-full max-w-md">
  <!-- Логотип -->
  <div class="text-center mb-8">
    <%= render Ui::LogoComponent.new %>
  </div>
  
  <!-- Форма входа -->
  <div class="border border-tui-border bg-tui-bg-secondary p-8 rounded">
    <h1 class="text-2xl font-bold mb-6 text-center text-barista-accent">
      Вход в систему
    </h1>
    
    <!-- Flash сообщения -->
    <% if flash[:alert] %>
      <div class="mb-4 p-3 bg-status-cancelled/10 border border-status-cancelled text-status-cancelled rounded text-sm">
        ⚠ <%= flash[:alert] %>
      </div>
    <% end %>
    
    <% if flash[:notice] %>
      <div class="mb-4 p-3 bg-status-ready/10 border border-status-ready text-status-ready rounded text-sm">
        ✓ <%= flash[:notice] %>
      </div>
    <% end %>
    
    <%= render Auth::LoginFormComponent.new(user: @user) %>
  </div>
  
  <!-- Footer -->
  <div class="mt-6 text-center text-tui-muted text-sm">
    CoffeeOS © 2025
  </div>
</div>
