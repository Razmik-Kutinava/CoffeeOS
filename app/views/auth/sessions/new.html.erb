<div class="w-full max-w-md">
  <!-- Логотип -->
  <div class="text-center mb-8">
    <%= render Ui::LogoComponent.new %>
  </div>
  
  <!-- Форма входа -->
  <div class="border border-tui-border bg-tui-bg-secondary p-8 rounded">
    <h1 class="text-2xl font-bold mb-6 text-center text-barista-accent">
      Вход в систему
    </h1>
    
    <!-- Flash сообщения -->
    <% if flash[:alert] %>
      <div class="mb-4 p-3 bg-status-cancelled/10 border border-status-cancelled text-status-cancelled rounded text-sm">
        ⚠ <%= flash[:alert] %>
      </div>
    <% end %>
    
    <% if flash[:notice] %>
      <div class="mb-4 p-3 bg-status-ready/10 border border-status-ready text-status-ready rounded text-sm">
        ✓ <%= flash[:notice] %>
      </div>
    <% end %>
    
    <%= render Auth::LoginFormComponent.new(user: @user) %>

    <div class="mt-6 text-tui-muted text-xs leading-relaxed">
      <p class="mb-2">
        Текущий хост: <code class="text-tui-text"><%= request.host_with_port %></code>.
        Сессия в браузере привязана к <strong>хосту</strong>: один и тот же логин на всех вкладках с этим адресом.
      </p>
      <p>
        Чтобы одновременно быть под разными пользователями (УК, офис, бариста и т.д.), откройте
        <strong>отдельное окно</strong> с <strong>другим хостом</strong>, например
        <code class="text-tui-text">uk.localhost</code>,
        <code class="text-tui-text">mgr.localhost</code>,
        <code class="text-tui-text">barista.localhost</code>
        (тот же порт, например <code class="text-tui-text">:3001</code>) или
        <code class="text-tui-text">127.0.0.1</code> vs <code class="text-tui-text">localhost</code>.
      </p>
    </div>
  </div>
  
  <!-- Footer -->
  <div class="mt-6 text-center text-tui-muted text-sm">
    CoffeeOS © 2025
  </div>
</div>
