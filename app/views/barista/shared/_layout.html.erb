<div class="barista-layout">
  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <h1>☕ CoffeeOS</h1>
    </div>
    
    <nav class="nav">
      <%= link_to barista_dashboard_path, class: "nav-item #{'active' if request.path == barista_dashboard_path}" do %>
        <span class="emoji">📋</span>
        <span>Заказы</span>
      <% end %>
      <%= link_to barista_new_order_path, class: "nav-item #{'active' if request.path == barista_new_order_path}" do %>
        <span class="emoji">➕</span>
        <span>Создать</span>
      <% end %>
      <%= link_to barista_menu_path, class: "nav-item #{'active' if request.path == barista_menu_path}" do %>
        <span class="emoji">📖</span>
        <span>Меню</span>
      <% end %>
      <%= link_to barista_shift_path, class: "nav-item #{'active' if request.path == barista_shift_path}" do %>
        <span class="emoji">⏰</span>
        <span>Смена</span>
      <% end %>
      <%= link_to barista_reports_path, class: "nav-item #{'active' if request.path == barista_reports_path}" do %>
        <span class="emoji">📊</span>
        <span>Отчёты</span>
      <% end %>
      <div style="flex: 1;"></div>
      <%= link_to '#', class: "nav-item" do %>
        <span class="emoji">⚙️</span>
        <span>Настройки</span>
      <% end %>
    </nav>

    <div class="user-section">
      <div class="user-avatar"><%= current_user.name&.first&.upcase || 'U' %></div>
      <div class="user-info">
        <div class="user-name"><%= current_user.name %></div>
        <div class="user-role">бариста</div>
      </div>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <!-- STATUS BAR -->
    <div class="status-bar">
      <div class="status-bar-header">
        <% if @shift %>
          <span class="dot"></span>
          <span class="status-bar-title">⏰ Смена: <%= @shift.opened_at.strftime('%H:%M') %>-<%= (@shift.opened_at + 12.hours).strftime('%H:%M') %></span>
        <% else %>
          <span class="dot" style="background: #f07c7c; box-shadow: 0 0 8px #f07c7c80;"></span>
          <span class="status-bar-title">Смена закрыта</span>
        <% end %>
        <span class="status-bar-tenant">Точка: <%= current_user.tenant&.name || 'Не указана' %></span>
      </div>
      <div class="status-bar-user">
        <span>👤 <%= current_user.name %></span>
        <%= button_to logout_path, method: :delete, data: { turbo_method: :delete }, class: "logout-btn-header", style: "background: transparent; border: none; cursor: pointer; color: #6e7b8c; padding: 4px 8px; border-radius: 4px; transition: all 0.15s;" do %>
          Выйти
        <% end %>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="content" id="content">
      <%= content_for?(:content) ? yield(:content) : yield %>
    </div>
  </main>

  <!-- MODAL (order detail) -->
  <div class="modal-overlay" id="modal-order-detail">
    <div class="modal">
      <div class="modal-header">
        <h2 id="modal-order-number">order #</h2>
        <div class="modal-close" onclick="closeModal('order-detail')">✕</div>
      </div>
      <div class="modal-body" id="modal-order-body">
        <!-- dynamic -->
      </div>
      <div class="modal-footer">
        <button class="btn btn-primary" onclick="closeModal('order-detail')">close</button>
        <button class="btn btn-success" onclick="printReceipt()">print receipt</button>
      </div>
    </div>
  </div>

  <!-- TOAST CONTAINER -->
  <div class="toast-container" id="toast"></div>
</div>

<style>
  /* ===== RESET & GLOBALS ===== */
  .barista-layout {
    background: #0b0d0e;
    font-family: 'SF Mono', 'JetBrains Mono', 'Fira Code', monospace;
    color: #e5e9f0;
    height: 100vh;
    display: flex;
    overflow: hidden;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  /* ===== SIDEBAR ===== */
  .sidebar {
    width: 180px;
    background: #0f1214;
    border-right: 1px solid #1e262c;
    display: flex;
    flex-direction: column;
    padding: 0;
    flex-shrink: 0;
  }

  .sidebar-header {
    padding: 20px 16px;
    border-bottom: 1px solid #1e262c;
  }

  .sidebar-header h1 {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.5px;
    color: #d4dcec;
    margin: 0;
  }

  .nav {
    flex: 1;
    padding: 12px 8px;
    display: flex;
    flex-direction: column;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 8px;
    color: #9aa8b9;
    font-size: 14px;
    margin-bottom: 4px;
    cursor: pointer;
    transition: all 0.15s ease;
    border: 1px solid transparent;
    background: transparent;
    width: 100%;
    text-align: left;
    font-family: inherit;
  }

  .nav-item:hover {
    background: #1a2126;
    color: #d4dcec;
    border-color: #2d3a44;
  }

  .nav-item.active {
    background: #1e2a33;
    color: #7bc5f0;
    border-color: #2d4c66;
  }

  .nav-item .emoji {
    font-size: 18px;
    filter: grayscale(0.3);
  }

  .user-section {
    padding: 16px;
    border-top: 1px solid #1e262c;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 6px;
    background: #1e2a33;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #7bc5f0;
    border: 1px solid #2d4c66;
    font-size: 14px;
    font-weight: 600;
  }

  .user-info {
    flex: 1;
  }

  .user-name {
    font-size: 13px;
    font-weight: 500;
    color: #d4dcec;
  }

  .user-role {
    font-size: 11px;
    color: #6e7b8c;
  }

  .logout-btn {
    color: #6e7b8c;
    cursor: pointer;
    font-size: 18px;
    transition: color 0.15s;
    text-decoration: none;
  }
  .logout-btn:hover { color: #f07c7c; }
  
  .logout-btn-header {
    color: #6e7b8c;
    cursor: pointer;
    font-size: 13px;
    transition: all 0.15s;
  }
  .logout-btn-header:hover { 
    color: #f07c7c; 
    background: #1e262c;
  }

  /* ===== MAIN PANEL ===== */
  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #0b0d0e;
  }

  .status-bar {
    height: 60px;
    background: #0f1214;
    border-bottom: 1px solid #1e262c;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    font-size: 13px;
    color: #9aa8b9;
  }
  
  .status-bar-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  
  .status-bar-title {
    font-size: 16px;
    font-weight: 500;
    color: #d4dcec;
  }
  
  .status-bar-time {
    color: #6e7b8c;
  }
  
  .status-bar-user {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .status-bar-tenant {
    color: #9aa8b9;
  }

  .status-left {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 10px;
    background: #3a9b5e;
    box-shadow: 0 0 8px #3a9b5e80;
  }

  .status-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .stat-value {
    color: #d4dcec;
    font-weight: 500;
  }

  /* ===== CONTENT AREA ===== */
  .content {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
    scrollbar-width: thin;
    scrollbar-color: #2d3a44 #0f1214;
  }

  .content::-webkit-scrollbar {
    width: 6px;
  }
  .content::-webkit-scrollbar-track {
    background: #0f1214;
  }
  .content::-webkit-scrollbar-thumb {
    background: #2d3a44;
    border-radius: 4px;
  }

  /* ===== DASHBOARD PAGE ===== */
  .dashboard-page {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  
  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid #1e262c;
  }
  
  .dashboard-title {
    font-size: 20px;
    font-weight: 500;
    color: #d4dcec;
    margin: 0;
  }
  
  .dashboard-meta {
    display: flex;
    gap: 16px;
    font-size: 13px;
    color: #6e7b8c;
  }
  
  .dashboard-footer {
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid #1e262c;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .footer-stats {
    display: flex;
    gap: 24px;
    font-size: 13px;
    color: #9aa8b9;
  }
  
  .footer-stats strong {
    color: #d4dcec;
    font-weight: 500;
  }
  
  .footer-hint {
    font-size: 12px;
    color: #6e7b8c;
  }

  /* ===== KANBAN BOARD ===== */
  .kanban {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    flex: 1;
    min-height: 0;
  }

  .column {
    background: #0f1214;
    border-radius: 12px;
    border: 1px solid #1e262c;
    display: flex;
    flex-direction: column;
    min-height: 500px;
    max-height: calc(100vh - 250px);
    overflow: hidden;
  }

  .column-header {
    padding: 16px;
    border-bottom: 1px solid #1e262c;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .column-title {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .column-title > span:first-of-type {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: #d4dcec;
  }
  
  .column-subtitle {
    font-size: 11px;
    color: #6e7b8c;
    margin-left: 18px;
  }
  
  .empty-column {
    text-align: center;
    padding: 40px 20px;
    color: #6e7b8c;
    font-size: 13px;
  }

  .column-dot {
    width: 10px;
    height: 10px;
    border-radius: 10px;
  }
  .dot-new { background: #7bc5f0; box-shadow: 0 0 8px #7bc5f080; }
  .dot-prep { background: #f0c97c; box-shadow: 0 0 8px #f0c97c80; }
  .dot-ready { background: #7cf0a0; box-shadow: 0 0 8px #7cf0a080; }

  .column-count {
    background: #1e262c;
    color: #9aa8b9;
    padding: 2px 8px;
    border-radius: 20px;
    font-size: 12px;
  }

  .cards {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #2d3a44 #0f1214;
  }
  
  .cards::-webkit-scrollbar {
    width: 6px;
  }
  .cards::-webkit-scrollbar-track {
    background: #0f1214;
  }
  .cards::-webkit-scrollbar-thumb {
    background: #2d3a44;
    border-radius: 4px;
  }

  /* ===== ORDER CARD ===== */
  .card {
    background: #141a1f;
    border: 1px solid #1e262c;
    border-radius: 10px;
    padding: 16px;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .card:hover {
    border-color: #2d4c66;
    transform: translateY(-1px);
    background: #1a2126;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .order-number {
    font-weight: 600;
    color: #d4dcec;
    font-size: 15px;
  }

  .order-badge {
    background: #1e262c;
    padding: 2px 8px;
    border-radius: 20px;
    font-size: 11px;
    color: #9aa8b9;
  }

  .card-items {
    margin-bottom: 12px;
  }

  .item-row {
    display: flex;
    gap: 8px;
    font-size: 13px;
    color: #b6c4d4;
    padding: 2px 0;
  }

  .item-qty {
    color: #7bc5f0;
    min-width: 24px;
  }

  .item-mod {
    color: #6e7b8c;
    font-size: 11px;
  }

  .card-customer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    padding-bottom: 8px;
    border-bottom: 1px dashed #1e262c;
    font-size: 12px;
  }
  
  .customer-level {
    color: #f0c97c;
    font-size: 11px;
  }
  
  .card-footer {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px dashed #1e262c;
  }
  
  .card-price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
  }
  
  .loyalty-badge {
    font-size: 11px;
    color: #7cf0a0;
    background: #1a3326;
    padding: 2px 6px;
    border-radius: 4px;
  }
  
  .promo-discount {
    font-size: 11px;
    color: #7cf0a0;
    margin-top: 4px;
  }
  
  .item-more {
    color: #6e7b8c;
    font-style: italic;
  }
  
  .ready-actions {
    display: flex;
    gap: 4px;
  }
  
  .btn-icon {
    padding: 8px;
    min-width: 36px;
  }

  .order-timer {
    font-size: 13px;
    color: #9aa8b9;
  }
  .timer-critical { color: #f07c7c; }
  .timer-warning { color: #f0c97c; }

  .order-price {
    font-weight: 600;
    color: #7cf0a0;
  }

  .card-actions {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }

  .btn {
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
    border: 1px solid transparent;
    background: transparent;
    color: #b6c4d4;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
  }

  .btn-primary {
    background: #1e2a33;
    border-color: #2d4c66;
    color: #7bc5f0;
    flex: 1;
  }
  .btn-primary:hover {
    background: #2d4c66;
    color: #e5e9f0;
  }

  .btn-danger {
    border-color: #4c2d2d;
    color: #f07c7c;
  }
  .btn-danger:hover {
    background: #4c2d2d;
    color: #ffa0a0;
  }

  .btn-success {
    background: #1a3326;
    border-color: #3a9b5e;
    color: #7cf0a0;
  }

  /* ===== MODAL ===== */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  .modal {
    background: #141a1f;
    border: 1px solid #2d4c66;
    border-radius: 16px;
    width: 480px;
    max-width: 90vw;
    max-height: 80vh;
    overflow-y: auto;
  }

  .modal-header {
    padding: 20px;
    border-bottom: 1px solid #1e262c;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .modal-header h2 {
    font-size: 18px;
    font-weight: 500;
    color: #d4dcec;
  }

  .modal-close {
    cursor: pointer;
    color: #6e7b8c;
    font-size: 24px;
  }

  .modal-body {
    padding: 20px;
  }

  .modal-footer {
    padding: 20px;
    border-top: 1px solid #1e262c;
    display: flex;
    gap: 12px;
    justify-content: flex-end;
  }

  /* ===== TOAST ===== */
  .toast-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 2000;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .toast {
    background: #1e2a33;
    border-left: 4px solid #7bc5f0;
    border-radius: 6px;
    padding: 12px 20px;
    color: #e5e9f0;
    font-size: 13px;
    box-shadow: 0 8px 16px rgba(0,0,0,0.5);
    animation: slideIn 0.2s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(100%); }
    to { opacity: 1; transform: translateX(0); }
  }
</style>

<script>
  // Navigation is handled by Rails links now

  function closeModal(modalId) {
    const modal = document.getElementById(`modal-${modalId}`);
    if (modal) {
      modal.classList.remove('active');
    }
  }
  
  function openModal(modalId) {
    const modal = document.getElementById(`modal-${modalId}`);
    if (modal) {
      modal.classList.add('active');
    }
  }
  
  function closePaymentModal() {
    const modal = document.getElementById('modal-payment');
    if (modal) {
      modal.classList.remove('active');
    }
  }
  
  function showToast(message, type = 'info') {
    const toastContainer = document.getElementById('toast');
    if (!toastContainer) return;
    
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.textContent = message;
    
    const colors = {
      success: '#7cf0a0',
      error: '#f07c7c',
      warning: '#f0c97c',
      info: '#7bc5f0'
    };
    
    toast.style.borderLeftColor = colors[type] || colors.info;
    toastContainer.appendChild(toast);
    
    setTimeout(() => {
      toast.style.opacity = '0';
      setTimeout(() => toast.remove(), 200);
    }, 3000);
  }

  function showOrderDetail(orderId) {
    fetch(`/barista/orders/${orderId}.json`)
      .then(response => response.json())
      .then(data => {
        document.getElementById('modal-order-number').textContent = `order ${data.order_number}`;
        
        const itemsHtml = data.order_items.map(item => `
          <tr>
            <td style="padding: 6px 0;">${item.quantity}× ${item.product_name}</td>
            <td style="color: #7bc5f0;">—</td>
            <td style="text-align: right;">${(item.price * item.quantity).toLocaleString('ru-RU')} ₽</td>
          </tr>
        `).join('');

        document.getElementById('modal-order-body').innerHTML = `
          <div style="margin-bottom: 20px;">
            <div style="display: flex; gap: 20px; margin-bottom: 16px;">
              <div><span style="color: #6e7b8c;">source</span><br>${data.source === 'kiosk' ? 'kiosk' : data.source === 'app' ? 'app' : 'manual'}</div>
              <div><span style="color: #6e7b8c;">status</span><br>${data.status}</div>
            </div>
            <table style="width: 100%; border-collapse: collapse;">
              <thead style="border-bottom: 1px solid #1e262c;">
                <tr><th style="text-align: left;">item</th><th>mod</th><th style="text-align: right;">price</th></tr>
              </thead>
              <tbody>${itemsHtml}</tbody>
              <tfoot style="border-top: 1px solid #1e262c;">
                <tr><td colspan="2" style="padding-top: 12px;">total</td><td style="text-align: right; font-weight: bold;">${data.final_amount.toLocaleString('ru-RU')} ₽</td></tr>
              </tfoot>
            </table>
          </div>
        `;
        
        document.getElementById('modal-order-detail').classList.add('active');
      })
      .catch(error => {
        console.error('Error loading order:', error);
      });
  }

  function printReceipt() {
    // TODO: Implement receipt printing
    console.log('Print receipt');
  }

  // Close modal on overlay click
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('modal-order-detail');
    if (modal) {
      modal.addEventListener('click', function(e) {
        if (e.target === this) closeModal('order-detail');
      });
    }
  });
</script>
