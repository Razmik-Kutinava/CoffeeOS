<nav class="fixed left-0 top-0 h-full w-72 bg-tui-bg-secondary border-r-2 border-tui-border z-40 backdrop-blur-xl" style="background: rgba(26, 31, 58, 0.95); box-shadow: 4px 0 30px rgba(0, 0, 0, 0.5), 0 0 40px var(--tui-border-glow);">
  <div class="p-6 border-b border-tui-border">
    <div class="text-3xl font-bold mb-1 text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, var(--barista-accent) 0%, var(--status-ready) 100%);">
      ☕ CoffeeOS
    </div>
    <div class="text-sm text-tui-muted mt-2 flex items-center">
      <span class="w-2 h-2 bg-status-ready rounded-full mr-2 animate-pulse" style="box-shadow: 0 0 10px var(--status-ready);"></span>
      <%= current_user.tenant&.name || 'Точка продаж' %>
    </div>
  </div>
  
  <div class="mt-6 px-4">
    <%= link_to barista_dashboard_path, class: "nav-item group px-6 py-4 mb-2 block rounded-xl transition-all duration-300 #{'active' if request.path == barista_dashboard_path}" do %>
      <span class="flex items-center text-lg">
        <span class="mr-3 text-xl">📋</span>
        <span class="font-semibold">Табло заказов</span>
      </span>
    <% end %>
    <%= link_to barista_new_order_path, class: "nav-item group px-6 py-4 mb-2 block rounded-xl transition-all duration-300 #{'active' if request.path == barista_new_order_path}" do %>
      <span class="flex items-center text-lg">
        <span class="mr-3 text-xl">➕</span>
        <span class="font-semibold">Новый заказ</span>
      </span>
    <% end %>
    <%= link_to barista_orders_history_path, class: "nav-item group px-6 py-4 mb-2 block rounded-xl transition-all duration-300 #{'active' if request.path == barista_orders_history_path}" do %>
      <span class="flex items-center text-lg">
        <span class="mr-3 text-xl">📜</span>
        <span class="font-semibold">История</span>
      </span>
    <% end %>
    <%= link_to barista_shift_path, class: "nav-item group px-6 py-4 mb-2 block rounded-xl transition-all duration-300 #{'active' if request.path == barista_shift_path}" do %>
      <span class="flex items-center text-lg">
        <span class="mr-3 text-xl">🔄</span>
        <span class="font-semibold">Смена</span>
      </span>
    <% end %>
  </div>
  
  <div class="absolute bottom-0 left-0 right-0 p-6 border-t-2 border-tui-border" style="background: rgba(26, 31, 58, 0.8);">
    <div class="flex items-center space-x-4 mb-4">
      <div class="w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-lg relative" style="background: var(--barista-gradient); box-shadow: 0 0 20px var(--status-accepted-glow);">
        <%= current_user.name&.first&.upcase || 'U' %>
        <div class="absolute -top-1 -right-1 w-4 h-4 bg-status-ready rounded-full border-2 border-tui-bg-secondary" style="box-shadow: 0 0 10px var(--status-ready);"></div>
      </div>
      <div>
        <div class="font-semibold text-tui-text-bright"><%= current_user.name %></div>
        <div class="text-sm text-tui-muted flex items-center">
          <span class="w-1.5 h-1.5 bg-barista-accent rounded-full mr-2" style="box-shadow: 0 0 8px var(--barista-accent);"></span>
          Бариста
        </div>
      </div>
    </div>
    <%= link_to logout_path, method: :delete, data: { turbo_method: :delete }, class: "w-full px-4 py-3 rounded-xl text-sm transition-all duration-300 text-center block font-semibold hover:scale-105 logout-btn" do %>
      🚪 Выйти
    <% end %>
  </div>
</nav>

<style>
  .nav-item {
    position: relative;
    color: var(--tui-muted);
    transition: all 0.3s ease;
  }
  
  .nav-item:hover {
    background: rgba(0, 212, 255, 0.1);
    color: var(--barista-accent);
    transform: translateX(5px);
    text-shadow: 0 0 10px var(--status-accepted-glow);
  }
  
  .nav-item.active {
    background: linear-gradient(90deg, rgba(0, 212, 255, 0.2) 0%, rgba(0, 212, 255, 0.05) 100%);
    border-left: 4px solid var(--barista-accent);
    color: var(--barista-accent);
    text-shadow: 0 0 15px var(--status-accepted-glow);
    box-shadow: inset 0 0 20px rgba(0, 212, 255, 0.1);
  }
  
  .nav-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--barista-accent);
    box-shadow: 0 0 20px var(--status-accepted-glow);
  }
  
  .logout-btn {
    background: rgba(255, 0, 110, 0.2);
    border: 1px solid var(--status-cancelled);
    color: var(--status-cancelled);
    box-shadow: 0 0 15px rgba(255, 0, 110, 0.3);
  }
  
  .logout-btn:hover {
    background: rgba(255, 0, 110, 0.3);
    box-shadow: 0 0 25px rgba(255, 0, 110, 0.5);
  }
</style>
