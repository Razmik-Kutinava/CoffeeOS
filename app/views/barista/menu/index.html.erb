<% content_for :content do %>
<div class="menu-page">
  <div class="menu-header">
    <h1 class="menu-title">📖 Меню</h1>
    <div class="menu-search">
      <input type="text" id="menu-search-input" placeholder="🔍 Поиск..." class="search-input">
    </div>
  </div>
  
  <% @categories.each do |category| %>
    <% category_products = @products.select { |p| p.category_id == category.id } %>
    <% next if category_products.empty? %>
    
    <div class="menu-category" data-category="<%= category.slug %>">
      <div class="category-header">
        <h2 class="category-title">
          <%= category.name %>
          <span class="category-count">[<%= category_products.count %> позиций]</span>
        </h2>
      </div>
      
      <div class="products-list">
        <% category_products.each do |product| %>
          <% setting = product.product_tenant_settings.find_by(tenant_id: Current.tenant_id) %>
          <div class="product-row" data-product-name="<%= product.name.downcase %>">
            <% if product.image_url.present? %>
              <img src="<%= product.image_url %>" alt="" class="product-thumb" width="48" height="48" loading="lazy" decoding="async">
            <% end %>
            <div class="product-info">
              <span class="product-name"><%= product.name %></span>
              <span class="product-price"><%= number_to_currency(setting&.price || 0, unit: '₽', format: '%n %u', delimiter: ' ') %></span>
            </div>
            <div class="product-status">
              <% if setting&.is_sold_out %>
                <span class="status-sold-out">⛔ Стоп (<%= setting.stock_qty == 0 ? 'Закончился' : 'Нет ингредиентов' %>)</span>
              <% else %>
                <span class="status-available">✅ В наличии</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  
  <div class="menu-footer">
    <div class="menu-note">⚠️ Редактирование меню доступно только офис-менеджеру</div>
  </div>
</div>
<% end %>

<%= render 'barista/shared/layout' %>

<style>
  .menu-page {
    max-width: 900px;
  }
  
  .menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid #1e262c;
  }
  
  .menu-title {
    font-size: 20px;
    font-weight: 500;
    color: #d4dcec;
    margin: 0;
  }
  
  .menu-search {
    flex: 1;
    max-width: 300px;
    margin-left: 24px;
  }
  
  .search-input {
    width: 100%;
    background: #141a1f;
    border: 1px solid #1e262c;
    border-radius: 8px;
    padding: 8px 12px;
    color: #e5e9f0;
    font-size: 13px;
    font-family: inherit;
  }
  
  .search-input:focus {
    outline: none;
    border-color: #2d4c66;
  }
  
  .menu-category {
    margin-bottom: 32px;
  }
  
  .category-header {
    margin-bottom: 16px;
  }
  
  .category-title {
    font-size: 16px;
    font-weight: 500;
    color: #d4dcec;
    margin: 0;
  }
  
  .category-count {
    font-size: 12px;
    color: #6e7b8c;
    font-weight: normal;
  }
  
  .products-list {
    background: #0f1214;
    border: 1px solid #1e262c;
    border-radius: 12px;
    overflow: hidden;
  }
  
  .product-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid #1e262c;
  }

  .product-thumb {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 8px;
    object-fit: cover;
    border: 1px solid #1e262c;
    background: #1a1f24;
  }
  
  .product-row:last-child {
    border-bottom: none;
  }
  
  .product-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex: 1;
    gap: 16px;
  }
  
  .product-name {
    color: #d4dcec;
    font-size: 14px;
  }
  
  .product-price {
    color: #7bc5f0;
    font-weight: 500;
    font-size: 14px;
  }
  
  .product-status {
    margin-left: 16px;
  }
  
  .status-available {
    color: #7cf0a0;
    font-size: 12px;
  }
  
  .status-sold-out {
    color: #f07c7c;
    font-size: 12px;
  }
  
  .menu-footer {
    margin-top: 32px;
    padding-top: 16px;
    border-top: 1px solid #1e262c;
  }
  
  .menu-note {
    font-size: 12px;
    color: #6e7b8c;
    text-align: center;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('menu-search-input');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        document.querySelectorAll('.product-row').forEach(row => {
          const productName = row.dataset.productName || '';
          if (productName.includes(query)) {
            row.style.display = 'flex';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }
  });
</script>
