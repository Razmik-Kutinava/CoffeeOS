<h1 class="pk-title">Склад цеха</h1>
<div class="pk-actions">
  <%= link_to "Все", prep_kitchen_inventory_path(filter: "all"), class: "pk-btn" %>
  <%= link_to "Low", prep_kitchen_inventory_path(filter: "low"), class: "pk-btn" %>
  <%= link_to "Out", prep_kitchen_inventory_path(filter: "out"), class: "pk-btn" %>
</div>

<div class="pk-card">
  <table class="pk-table">
    <thead><tr><th>Ингредиент</th><th>Остаток</th><th>Мин.</th><th>Действия</th></tr></thead>
    <tbody>
      <% @stocks.each do |stock| %>
        <tr>
          <td><%= stock.ingredient&.name %></td>
          <td><%= stock.qty %></td>
          <td><%= stock.min_qty %></td>
          <td>
            <% if Current.role_code == "prep_kitchen_manager" %>
              <%= form_with url: prep_kitchen_inventory_min_qty_path(stock), method: :patch, local: true do |f| %>
                <%= f.number_field :min_qty, value: stock.min_qty, step: 0.001, class: "pk-input" %>
                <%= f.submit "Сохранить", class: "pk-btn" %>
              <% end %>
            <% else %>
              <span class="pk-muted">только просмотр</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
