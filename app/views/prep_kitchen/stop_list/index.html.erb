<h1 class="pk-title">Стоп-лист цеха</h1>
<div class="pk-card">
  <table class="pk-table">
    <thead><tr><th>Продукт</th><th>Причина</th><th>Обновлено</th><th>Действия</th></tr></thead>
    <tbody>
      <% @items.each do |item| %>
        <tr>
          <td><%= item.product&.name %></td>
          <td><%= item.sold_out_reason %></td>
          <td><%= item.updated_at&.strftime("%d.%m %H:%M") %></td>
          <td>
            <% if Current.role_code == "prep_kitchen_manager" %>
              <%= form_with model: item, url: prep_kitchen_stop_list_item_path(item), method: :patch, local: true do |f| %>
                <%= f.hidden_field :is_sold_out, value: false %>
                <%= f.submit "Снять стоп", class: "pk-btn" %>
              <% end %>
            <% else %>
              <span class="pk-muted">только просмотр</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
