<div class="page">
  <div class="page-header">
    <h1 class="page-title">🧭 Дашборд офиса</h1>
    <div class="page-subtitle">Операционный контроль точки за 60 секунд</div>
  </div>

  <div class="grid">
    <section class="card">
      <div class="card-title">Point Health (MVP)</div>
      <div class="card-muted">Далее добавим светофор и автообновление через Turbo Streams.</div>
    </section>

    <section class="card">
      <div class="card-title">Queue Center (MVP)</div>
      <div class="card-muted">Далее добавим список инцидентов и быстрые фиксы.</div>
    </section>
  </div>

  <div class="grid grid-2">
    <section class="card">
      <div class="card-title">Последние заказы</div>
      <% if @recent_orders.any? %>
        <div class="table">
          <% @recent_orders.each do |o| %>
            <div class="row">
              <div class="row-main">
                <%= link_to o.order_number, manager_order_path(o), class: "link" %>
                <span class="pill"><%= o.status %></span>
              </div>
              <div class="row-meta">
                <span><%= o.final_amount %> ₽</span>
                <span class="muted"><%= o.created_at&.strftime("%d.%m %H:%M") %></span>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty">Нет данных</div>
      <% end %>
    </section>

    <section class="card">
      <div class="card-title">Проблемные зоны (черновик)</div>
      <div class="card-muted">Платежи/чеки/устройства/склад будут собраны в инциденты.</div>

      <div class="mini">
        <div class="mini-item"><span class="muted">Платежи</span> <span class="pill pill-warn">скоро</span></div>
        <div class="mini-item"><span class="muted">Фискализация</span> <span class="pill pill-warn">скоро</span></div>
        <div class="mini-item"><span class="muted">Устройства</span> <span class="pill pill-warn">скоро</span></div>
        <div class="mini-item"><span class="muted">Склад</span> <span class="pill pill-warn">скоро</span></div>
      </div>
    </section>
  </div>
</div>

<style>
  .page { max-width: 1200px; margin: 0 auto; }
  .page-header { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
  .page-title { margin: 0; font-size: 22px; color: var(--tui-text-bright); letter-spacing: 0.3px; }
  .page-subtitle { color: var(--tui-muted); font-size: 13px; }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
  .grid-2 { grid-template-columns: 2fr 1fr; }

  .card {
    background: rgba(26, 31, 58, 0.65);
    border: 1px solid var(--tui-border);
    border-radius: 16px;
    padding: 16px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
  }
  .card-title { font-weight: 700; color: var(--tui-text-bright); margin-bottom: 8px; }
  .card-muted { color: var(--tui-muted); font-size: 12px; }

  .table { display: flex; flex-direction: column; gap: 8px; margin-top: 10px; }
  .row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 12px; border-radius: 14px;
    border: 1px solid rgba(139, 92, 246, 0.18);
    background: rgba(10, 14, 39, 0.35);
  }
  .row-main { display: flex; align-items: center; gap: 10px; }
  .row-meta { display: flex; align-items: center; gap: 10px; color: var(--tui-text); }
  .link { color: var(--neon-blue); text-decoration: none; font-weight: 700; }
  .link:hover { text-decoration: underline; }
  .muted { color: var(--tui-muted); }
  .pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; padding: 2px 8px; border-radius: 999px;
    border: 1px solid rgba(139, 92, 246, 0.35);
    color: var(--tui-text-bright);
    background: rgba(139, 92, 246, 0.12);
  }
  .pill-warn {
    border-color: rgba(255, 215, 0, 0.35);
    background: rgba(255, 215, 0, 0.08);
  }
  .empty { margin-top: 10px; color: var(--tui-muted); font-size: 13px; }

  .mini { margin-top: 10px; display: flex; flex-direction: column; gap: 8px; }
  .mini-item { display: flex; justify-content: space-between; align-items: center; }

  @media (max-width: 1100px) {
    .grid, .grid-2 { grid-template-columns: 1fr; }
  }
</style>

