<%= form_with model: user, url: user.persisted? ? manager_staff_member_path(user) : manager_staff_members_path, method: user.persisted? ? :patch : :post, class: "card", style: "padding: 1.25rem; max-width: 520px;" do |f| %>
  <% if user.errors.any? %>
    <div class="card-muted" style="color: #f87171; margin-bottom: 1rem;"><%= user.errors.full_messages.to_sentence %></div>
  <% end %>

  <div style="margin-bottom: 0.75rem;">
    <%= f.label :name, "Имя", style: "display:block; margin-bottom: 4px;" %>
    <%= f.text_field :name, required: true, style: "width: 100%; padding: 8px;" %>
  </div>
  <div style="margin-bottom: 0.75rem;">
    <%= f.label :email, "Email", style: "display:block; margin-bottom: 4px;" %>
    <%= f.email_field :email, style: "width: 100%; padding: 8px;" %>
  </div>
  <div style="margin-bottom: 0.75rem;">
    <%= f.label :phone, "Телефон", style: "display:block; margin-bottom: 4px;" %>
    <%= f.text_field :phone, style: "width: 100%; padding: 8px;" %>
  </div>
  <div style="margin-bottom: 0.75rem;">
    <%= f.label :password, user.persisted? ? "Новый пароль (оставьте пустым — не менять)" : "Пароль", style: "display:block; margin-bottom: 4px;" %>
    <%= f.password_field :password, style: "width: 100%; padding: 8px;" %>
  </div>

  <div class="card-title" style="margin-top: 1rem;">Роли на этой точке</div>
  <% assignable_staff_role_codes.each do |code| %>
    <% role = Role.find_by(code: code) %>
    <% next unless role %>
    <label style="display: block; margin: 6px 0;">
      <%= check_box_tag "role_codes[]", code, user.persisted? && user.roles.exists?(code: code), id: "role_#{code}" %>
      <%= role.code %>
    </label>
  <% end %>

  <%= f.submit user.persisted? ? "Сохранить" : "Создать", style: "margin-top: 1rem; padding: 10px 16px; cursor: pointer;" %>
<% end %>
