<div class="page">
  <div class="page-header">
    <h1 class="page-title">🍽️ Меню точки</h1>
    <div class="page-subtitle">
      В этой панели можно менять только цену товара для текущей точки.
    </div>
  </div>

  <div class="card">
    <% if @settings.any? %>
      <div class="table">
        <% @settings.each do |s| %>
          <div class="row">
            <div class="row-main" style="display:flex; align-items:center; gap:12px;">
              <% p = s.product %>
              <% if p&.image_url.present? %>
                <img src="<%= p.image_url %>" alt="" width="40" height="40" style="border-radius:8px; object-fit:cover; border:1px solid #e5e7eb; flex-shrink:0;" loading="lazy">
              <% end %>
              <span class="link" style="cursor: default; text-decoration: none;"><%= p&.name || "product##{s.product_id}" %></span>
            </div>
            <div class="row-meta">
              <% if office_or_franchise_manager? %>
                <%= form_with url: manager_menu_setting_price_path(s), method: :patch, local: true, style: "display:flex; gap:8px; align-items:center;" do %>
                  <input type="number" step="0.01" name="product_tenant_setting[price]" value="<%= s.price %>" style="width: 140px;">
                  <button type="submit">Сохранить цену</button>
                <% end %>
              <% else %>
                <span class="pill">price: <%= s.price %> ₽</span>
              <% end %>
              <span class="muted"><%= s.is_enabled ? "enabled" : "disabled" %></span>
              <% if s.is_sold_out %>
                <span class="pill" style="color: var(--status-cancelled);">sold_out<% if s.sold_out_reason.present? %> · <%= s.sold_out_reason %><% end %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty">Нет настроек меню</div>
    <% end %>
  </div>
</div>

<%= render "manager/shared/page_styles" %>

