<!DOCTYPE html>
<html>
  <head>
    <title>Prep Kitchen | CoffeeOS</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="prep-kitchen-shell">
    <div class="pk-app">
      <%= render "prep_kitchen/shared/sidebar" %>
      <main class="pk-content">
        <% if flash[:notice].present? %>
          <div class="pk-flash pk-flash-notice"><%= flash[:notice] %></div>
        <% end %>
        <% if flash[:alert].present? %>
          <div class="pk-flash pk-flash-alert"><%= flash[:alert] %></div>
        <% end %>
        <%= yield %>
      </main>
    </div>
    <%= render "prep_kitchen/shared/page_styles" %>
  </body>
</html>
