<h1 style="font-size: 1.5rem; margin-bottom: 16px;">Дашборд УК</h1>

<section style="margin-bottom: 24px;">
  <h2 style="font-size: 1.1rem;">Организации</h2>
  <%= link_to "Все организации", platform_organizations_path, style: "color: #93c5fd;" %> ·
  <%= link_to "Новая", new_platform_organization_path, style: "color: #93c5fd;" %>
</section>

<section style="margin-bottom: 24px;">
  <h2 style="font-size: 1.1rem;">Точки</h2>
  <%= link_to "Все точки", platform_tenants_path, style: "color: #93c5fd;" %> ·
  <%= link_to "Новая точка", new_platform_tenant_path, style: "color: #93c5fd;" %>
</section>

<section style="margin-bottom: 24px;">
  <h2 style="font-size: 1.1rem;">Каталог</h2>
  <%= link_to "Управление меню", platform_menu_path, style: "color: #93c5fd;" %>
</section>

<table style="width: 100%; border-collapse: collapse; font-size: 13px;">
  <thead>
    <tr style="text-align: left; border-bottom: 1px solid #334155;">
      <th style="padding: 8px;">Точка</th>
      <th style="padding: 8px;">Организация</th>
      <th style="padding: 8px;"></th>
    </tr>
  </thead>
  <tbody>
    <% @tenants.each do |t| %>
      <tr style="border-bottom: 1px solid #1e293b;">
        <td style="padding: 8px;"><%= t.name %></td>
        <td style="padding: 8px;"><%= t.organization&.name || "—" %></td>
        <td style="padding: 8px;">
          <%= button_to "Панель менеджера", open_as_manager_platform_tenant_path(t), method: :post, form: { style: "display:inline;" } %>
          <%= link_to "Правка", edit_platform_tenant_path(t), style: "color: #93c5fd; margin-left: 8px;" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
