<div class="platform-menu" id="top">
  <h1>Управление меню (УК)</h1>
  <p class="pm-intro pm-intro--compact">
    Категория → товар → цены по точкам как раньше. Каталог ниже — раскрывайте строки.
  </p>

  <nav class="pm-nav" aria-label="Быстрые ссылки">
    <a href="#new-category">Новая категория</a>
    <a href="#new-product">Новый товар</a>
    <a href="#catalog">Каталог</a>
  </nav>

  <div class="pm-grid-2">
    <section class="pm-card pm-card--compact" id="new-category">
      <h2>Новая категория</h2>
      <%= form_with url: platform_menu_categories_path, method: :post, local: true, html: { class: "pm-form" } do |f| %>
        <div class="pm-field">
          <label class="pm-label" for="new_cat_name">Название</label>
          <%= f.text_field :name, id: "new_cat_name", name: "category[name]", placeholder: "Например, Кофе", required: true %>
        </div>
        <div class="pm-row-2">
          <div class="pm-field">
            <label class="pm-label" for="new_cat_slug">Slug</label>
            <%= f.text_field :slug, id: "new_cat_slug", name: "category[slug]", placeholder: "авто из названия" %>
          </div>
          <div class="pm-field">
            <label class="pm-label" for="new_cat_order">Порядок</label>
            <%= f.number_field :sort_order, id: "new_cat_order", name: "category[sort_order]", value: 0, min: 0, title: "0 — в конец списка" %>
          </div>
        </div>
        <div class="pm-field">
          <label class="pm-label" for="new_cat_desc">Описание</label>
          <%= f.text_area :description, id: "new_cat_desc", name: "category[description]", placeholder: "Необязательно", rows: 3 %>
        </div>
        <input type="hidden" name="category[is_active]" value="0">
        <label class="pm-check">
          <%= check_box_tag "category[is_active]", "1", true %> Активна на витрине
        </label>
        <div>
          <%= f.submit "Добавить категорию", class: "pm-btn pm-btn--primary" %>
        </div>
      <% end %>
    </section>

    <section class="pm-card pm-card--compact" id="new-product">
      <h2>Новый товар</h2>
      <%= form_with url: platform_menu_products_path, method: :post, local: true, html: { multipart: true, class: "pm-form" } do |f| %>
        <div class="pm-field">
          <label class="pm-label" for="new_prod_cat">Категория</label>
          <% cat_opts = options_from_collection_for_select(@categories, :id, :name, @prefill_category_id) %>
          <% if @prefill_category_id.present? %>
            <%= select_tag "product[category_id]", cat_opts, id: "new_prod_cat", required: true %>
          <% else %>
            <%= select_tag "product[category_id]", cat_opts, include_blank: "Выберите категорию", id: "new_prod_cat", required: true %>
          <% end %>
        </div>
        <div class="pm-row-2">
          <div class="pm-field">
            <label class="pm-label" for="new_prod_name">Название</label>
            <%= f.text_field :name, id: "new_prod_name", name: "product[name]", required: true %>
          </div>
          <div class="pm-field">
            <label class="pm-label" for="new_prod_slug">Slug</label>
            <%= f.text_field :slug, id: "new_prod_slug", name: "product[slug]", placeholder: "авто" %>
          </div>
        </div>
        <div class="pm-field">
          <label class="pm-label" for="new_prod_desc">Описание для витрины</label>
          <%= f.text_area :description, id: "new_prod_desc", name: "product[description]", rows: 4 %>
        </div>
        <div class="pm-row-2">
          <div class="pm-field">
            <label class="pm-label" for="new_prod_price">Базовая цена, ₽</label>
            <%= f.number_field :base_price, id: "new_prod_price", name: "product[base_price]", step: 0.01, min: 0.01, required: true %>
          </div>
          <div class="pm-field">
            <label class="pm-label" for="new_prod_sort">Порядок в категории</label>
            <%= f.number_field :sort_order, id: "new_prod_sort", name: "product[sort_order]", value: 0, min: 0 %>
          </div>
        </div>
        <div class="pm-field">
          <label class="pm-label" for="new_prod_img_url">Фото по ссылке (необязательно)</label>
          <%= f.url_field :image_url, id: "new_prod_img_url", name: "product[image_url]", placeholder: "https://…" %>
        </div>
        <div class="pm-field">
          <label class="pm-label" for="new_prod_img_file">Или загрузить файл</label>
          <%= f.file_field :image, id: "new_prod_img_file", name: "product[image]", accept: "image/jpeg,image/png,image/webp,image/gif" %>
          <p class="pm-hint">JPEG, PNG, WebP или GIF, до 5 МБ. Файл перезаписывает ссылку.</p>
        </div>
        <input type="hidden" name="product[is_active]" value="0">
        <label class="pm-check">
          <%= check_box_tag "product[is_active]", "1", true %> Активен
        </label>
        <div>
          <%= f.submit "Добавить товар", class: "pm-btn pm-btn--primary" %>
        </div>
      <% end %>
    </section>
  </div>

  <h2 class="pm-catalog-title" id="catalog">Каталог</h2>
  <% if @categories.empty? %>
    <p class="pm-intro">Пока нет категорий — создайте первую выше.</p>
  <% else %>
    <% @categories.each do |cat| %>
      <%= render "category_section", cat: cat %>
    <% end %>
  <% end %>
</div>
