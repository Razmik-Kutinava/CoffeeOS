<%= form_with url: login_path, method: :post, local: true, 
    data: { controller: "login-form", login_form_target: "form" },
    class: "space-y-4" do |f| %>
  
  <!-- Email/Phone поле -->
  <div>
    <%= f.label :email, "Email или телефон", 
        class: "block text-sm font-medium mb-2 text-tui-text" %>
    <%= f.text_field :email, 
        value: user.email,
        placeholder: "user@example.com или +79991234567",
        autocomplete: "email",
        required: true,
        class: "w-full px-4 py-2 bg-tui-bg border border-tui-border rounded text-tui-text placeholder-tui-muted focus:border-barista-accent focus:ring-2 focus:ring-barista-accent/20 outline-none transition-all font-mono",
        data: { login_form_target: "email", action: "input->login-form#validate" } %>
    <div data-login-form-target="emailError" class="hidden mt-1 text-xs text-status-cancelled"></div>
  </div>
  
  <!-- Password поле -->
  <div>
    <%= f.label :password, "Пароль", 
        class: "block text-sm font-medium mb-2 text-tui-text" %>
    <%= f.password_field :password, 
        placeholder: "••••••••",
        autocomplete: "current-password",
        required: true,
        class: "w-full px-4 py-2 bg-tui-bg border border-tui-border rounded text-tui-text placeholder-tui-muted focus:border-barista-accent focus:ring-2 focus:ring-barista-accent/20 outline-none transition-all font-mono",
        data: { login_form_target: "password", action: "input->login-form#validate" } %>
    <div data-login-form-target="passwordError" class="hidden mt-1 text-xs text-status-cancelled"></div>
  </div>
  
  <!-- Кнопка входа -->
  <div>
    <%= f.submit "Войти", 
        class: "w-full px-4 py-3 bg-barista-accent text-white rounded font-medium hover:opacity-80 transition-opacity focus:ring-2 focus:ring-barista-accent/50 outline-none cursor-pointer",
        data: { login_form_target: "submit", action: "click->login-form#handleSubmit" } %>
  </div>
  
  <!-- Сообщение об успехе (скрыто по умолчанию) -->
  <div data-login-form-target="success" class="hidden p-3 bg-status-ready/10 border border-status-ready text-status-ready rounded text-sm text-center">
    ✓ Данные корректны
  </div>
<% end %>
