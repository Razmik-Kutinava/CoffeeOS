#!/usr/bin/env ruby
# Витрина /shop: Rails (порт 3000) + Vite (HMR). Без Vite: bin/server или bin/dev --rails-only
APP_ROOT = File.expand_path("..", __dir__)
Dir.chdir(APP_ROOT)
load File.expand_path("../config/bundle_env.rb", __dir__)
AppBundleEnv.apply!(ENV)

if ARGV.include?("--rails-only")
  exec Gem.ruby, File.join(APP_ROOT, "bin", "rails"), "server", "-p", "3000", *(ARGV - ["--rails-only"])
else
  exec Gem.ruby, "-S", "bundle", "exec", "foreman", "start", "-f", "Procfile.dev"
end
