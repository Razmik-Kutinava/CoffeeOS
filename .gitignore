# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Bundler: не коммитим кэш, но path к гемам — в репо (удобно для WSL без sudo)
/.bundle/*
!/.bundle/config

# Гемы в каталоге проекта (`path vendor/bundle`)
/vendor/bundle/

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Загрузки фото товаров УК (public/uploads/products)
/public/uploads/

# Ignore key files for decrypting credentials and more.
/config/*.key

# Local Postgres test cluster (never commit)
/.pg_test/

# Local scratch/notes file
/qc

# Coverage reports (e.g. SimpleCov)
/coverage/

# Node + Vite (витрина shop)
/node_modules/
/public/vite-dev
/public/vite-test
/public/vite-ssr

# Editor/OS noise
.DS_Store
Thumbs.db

# Локальные docs/ и .claude/ не коммитим: добавь у себя в .git/info/exclude строки /docs/ и /.claude/
/benchmark

# VSCode settings
.vscode/

# Claude Code free-claude-code
/free-claude-code/

# GitHub Actions и настройки
/.github/

# Cursor IDE настройки
/.cursor/

# Все markdown файлы кроме README.md и doc/features/
*.md
!README.md
!doc/**/*.md

# Vite Ruby
/public/vite*
node_modules
# Vite uses dotenv and suggests to ignore local-only env files. See
# https://vitejs.dev/guide/env-and-mode.html#env-files
*.local

